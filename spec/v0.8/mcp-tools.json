    {
      "name": "report_introduction_outcome",
      "description": "Report the outcome of an introduction when it concludes. The outcome_code values cover successful introductions, professional declines, consumer cancellations, no-response, and concern reports. The consumer-reported-concern outcome routes to the concern flag mechanism (spec §5.10) — admin-only visibility, professional notified with right of reply. ATAH does not adjudicate; serious matters route to the relevant regulatory or professional body.",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "handoff_id": {
            "type": "string",
            "pattern": "^hf-[A-Za-z0-9-]{6,64}$"
          },
          "handoff_access_token": {
            "type": "string",
            "minLength": 1
          },
          "outcome_code": {
            "type": "string",
            "enum": [
              "introduction-successful",
              "professional-declined-conflict",
              "professional-declined-scope",
              "professional-declined-capacity",
              "professional-declined-fee",
              "professional-declined-other",
              "consumer-chose-alternative",
              "matter-not-proceeding",
              "no-response-from-consumer",
              "consumer-reported-concern",
              "consumer-cancelled",
              "consent-revoked"
            ]
          },
          "outcome_notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "handoff_id",
          "handoff_access_token",
          "outcome_code"
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "current_state": {
            "type": "string",
            "minLength": 1
          },
          "confirmation_id": {
            "type": "string",
            "minLength": 1
          },
          "concern_flag_id": {
            "type": "string",
            "pattern": "^flag-[A-Za-z0-9-]{6,64}$",
            "description": "Present when outcome_code is consumer-reported-concern."
          }
        },
        "required": [
          "current_state",
          "confirmation_id"
        ],
        "additionalProperties": false
      },
      "error_codes": [
        "handoff_access_token_invalid",
        "handoff_access_token_expired",
        "handoff_not_found",
        "validation_error"
      ],
      "safety_metadata": {
        "is_read_only": false,
        "transmits_personal_data": false,
        "requires_explicit_user_approval": false,
        "state_change_scope": "handoff"
