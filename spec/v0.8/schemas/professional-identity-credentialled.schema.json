        }
      ],
      "enhanced_verification": [],
      "data_conflicts": [],
      "ai_assistant_connected": true,
      "profile_completeness_score": 0.92,
      "looking_for_referral_partners": false,
      "notification_channels": [
        {
          "channel_id": "ch-01HQXRQ1A2BCDEFGHIJKLMNOPQ",
          "channel_type": "email",
          "destination_reference": "hmac:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "delivery_purpose": "handoff_stage_1",
          "is_primary": true,
          "last_verified": "2026-04-08T09:15:00Z",
