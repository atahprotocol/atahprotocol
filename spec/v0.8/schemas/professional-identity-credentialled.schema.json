{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/professional-identity-credentialled.schema.json",
  "title": "ATAH Professional Identity — Credentialled Tier",
  "description": "ATAH Core Protocol object: credentialled-tier professional profile (spec/v0.8 Section 4.6). Required for any ATAH-conformant implementation that produces or consumes professional profile objects.",
  "type": "object",
  "properties": {
    "atah_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "schema_version": { "type": "string", "const": "0.8" },
    "protocol_version": { "type": "string", "const": "0.8" },
    "professional_tier": { "type": "string", "const": "credentialled" },
    "category": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "firm": { "type": "string", "minLength": 1 },
    "licensed_jurisdictions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "service_locations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "physical_locations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "remote_service_available": { "type": "boolean" },
    "specialisms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "matter_types": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "matching_status": {
      "type": "string",
      "enum": [
        "active",
        "compliance-pending",
        "regulatory-suspended",
        "admin-suspended",
        "pending-rollup",
        "pending-integrity-review",
        "withdrawn",
        "deceased"
      ]
    },
    "matching_status_reason": { "type": "string", "minLength": 1 },
    "registration_route": {
      "type": "string",
      "enum": ["partner", "individual"]
    },
    "licence": {
      "type": "object",
      "properties": {
        "number": { "type": "string", "minLength": 1 },
        "issuing_body": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "suspended", "revoked"]
        },
        "verified_at": { "type": "string", "format": "date-time" },
        "disciplinary_record": {
          "type": "string",
          "enum": ["none_found", "present", "under_review"]
        }
      },
      "required": ["number", "issuing_body", "status", "verified_at", "disciplinary_record"],
      "additionalProperties": false
    },
    "experience": {
      "type": "object",
      "properties": {
        "years_in_practice": { "type": "integer", "minimum": 0 },
        "years_in_specialism": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "response_time": {
      "type": "object",
      "properties": {
        "declared_hours": { "type": "integer", "minimum": 0 },
        "applies_to": {
          "type": "string",
          "enum": ["working_hours", "wall_clock_hours"]
        },
        "operating_timezone": {
          "type": "string",
          "minLength": 1,
          "description": "IANA timezone name."
        }
      },
      "required": ["declared_hours", "applies_to", "operating_timezone"],
      "additionalProperties": false
    },
    "engagement": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "virtual": { "type": "boolean" },
        "languages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z]{2,3}$" },
          "uniqueItems": true
        },
        "availability": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "referral_network": {
      "type": "object",
      "properties": {
        "inbound_relationship_count": { "type": "integer", "minimum": 0 },
        "inbound_relationship_quality_score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "trusted_partner_data": {
      "type": "array",
      "items": { "$ref": "#/$defs/PartnerDataPayload" }
    },
    "enhanced_verification": {
      "type": "array",
      "items": {
        "$ref": "enhanced-verification.schema.json"
      }
    },
    "data_conflicts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "ai_assistant_connected": { "type": "boolean" },
    "profile_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "profile_maintained": { "type": "boolean" },
    "_provenance": {
      "$ref": "provenance-map.schema.json"
    }
  },
  "required": [
    "atah_id",
    "schema_version",
    "protocol_version",
    "professional_tier",
    "category",
    "name",
    "service_locations",
    "remote_service_available",
    "specialisms",
    "matching_status",
    "registration_route",
    "licence"
  ],
  "additionalProperties": false,
  "$defs": {
    "PartnerDataPayload": {
      "type": "object",
      "properties": {
        "partner_id": {
          "type": "string",
          "pattern": "^tp-[A-Za-z0-9-]{6,64}$"
        },
        "partner_name": { "type": "string", "minLength": 1 },
        "partner_type": {
          "type": "string",
          "enum": [
            "regulatory_database",
            "professional_body",
            "review_platform",
            "independent_verifier",
            "firm_or_institution"
          ]
        },
        "data_points": {
          "type": "object",
          "description": "Partner-supplied structured data points. Open object — content varies by partner_type and category.",
          "additionalProperties": true
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "trust_tier": {
          "type": "string",
          "enum": ["partner-verified", "probationary-partner", "suspended-partner", "revoked-partner"]
        }
      },
      "required": ["partner_id", "partner_name", "partner_type", "data_points", "last_updated", "trust_tier"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "atah_id": "atah-01HQXR7K9NBVZ8M3PXFG2YT5WA",
      "schema_version": "0.8",
      "protocol_version": "0.8",
      "professional_tier": "credentialled",
      "category": "lawyer",
      "name": "Jane Smith",
      "firm": "Smith Legal LLC",
      "licensed_jurisdictions": ["US-TX", "US-NY"],
      "service_locations": ["US-TX", "US-NY"],
      "physical_locations": ["Austin, TX"],
      "remote_service_available": true,
      "specialisms": ["commercial_contracts", "employment_law"],
      "matter_types": ["contract_review", "employment_dispute"],
      "matching_status": "active",
      "registration_route": "individual",
      "licence": {
        "number": "TX-BAR-12345",
        "issuing_body": "State Bar of Texas",
        "status": "active",
        "verified_at": "2026-04-01T00:00:00Z",
        "disciplinary_record": "none_found"
      },
      "experience": { "years_in_practice": 18, "years_in_specialism": 12 },
      "response_time": {
        "declared_hours": 24,
        "applies_to": "working_hours",
        "operating_timezone": "America/Chicago"
      },
      "engagement": {
        "model": "fixed_fee_and_hourly",
        "virtual": true,
        "languages": ["en", "es"],
        "availability": "accepting_new_matters"
      },
      "referral_network": {
        "inbound_relationship_count": 7,
        "inbound_relationship_quality_score": 0.84
      },
      "trusted_partner_data": [
        {
          "partner_id": "tp-statebar-tx-001",
          "partner_name": "State Bar of Texas",
          "partner_type": "regulatory_database",
          "data_points": {
            "licence_status": "active",
            "disciplinary_record": "none_found",
            "admission_date": "2008-09-15"
          },
          "last_updated": "2026-04-01T00:00:00Z",
          "trust_tier": "partner-verified"
        }
      ],
      "enhanced_verification": [],
      "data_conflicts": [],
      "ai_assistant_connected": true,
      "profile_completeness_score": 0.92,
      "_provenance": {
        "name": { "verification_status": "partner-verified", "source": "tp-statebar-tx-001", "as_of": "2026-04-01T00:00:00Z" },
        "firm": { "verification_status": "self-declared", "source": "professional", "as_of": "2026-03-15T00:00:00Z" },
        "licensed_jurisdictions": { "verification_status": "partner-verified", "source": "tp-statebar-tx-001", "as_of": "2026-04-01T00:00:00Z" },
        "specialisms": { "verification_status": "self-declared", "source": "professional", "as_of": "2026-03-15T00:00:00Z" },
        "licence.number": { "verification_status": "registry-verified", "source": "atah-registry", "as_of": "2026-04-01T00:00:00Z" },
        "licence.status": { "verification_status": "registry-verified", "source": "atah-registry", "as_of": "2026-04-01T00:00:00Z" },
        "licence.disciplinary_record": { "verification_status": "partner-verified", "source": "tp-statebar-tx-001", "as_of": "2026-04-01T00:00:00Z" }
      }
    }
  ]
}
