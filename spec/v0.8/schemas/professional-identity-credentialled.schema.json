        },
        {
          "channel_id": "ch-01HQXRQ2B3CDEFGHIJKLMNOPQR",
          "channel_type": "phone_sms",
          "destination_reference": "hmac:5feceb66ffc86f38d952786c6d696c79c2dbc239dd4e91b46729d73a27fb57e9",
          "delivery_purpose": "handoff_stage_3",
