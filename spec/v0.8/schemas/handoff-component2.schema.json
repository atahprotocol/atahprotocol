{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/handoff-component2.schema.json",
  "title": "ATAH Handoff — Component 2 (Consumer-self handoff)",
  "description": "ATAH Core Protocol object: Component 2 consumer-self handoff record (spec/v0.8 Sections 6 and 11.5). Available only when the originating Discovery query had `request_intent: 'self'`. Three flow variants are supported (`off_protocol`, `contact_share`, `full_lifecycle`); the full Stage 1 / Stage 2 / Stage 3 state machine is preserved as the `full_lifecycle` variant. Required for any ATAH-conformant implementation.",
  "type": "object",
  "properties": {
    "handoff_id": {
      "type": "string",
      "pattern": "^hf-[A-Za-z0-9-]{6,64}$"
    },
    "schema_version": { "type": "string", "const": "0.8" },
    "protocol_version": { "type": "string", "const": "0.8" },
    "introduction_type": {
      "type": "string",
      "enum": ["component_2_consumer_handoff"]
    },
    "flow_variant": {
      "type": "string",
      "enum": ["off_protocol", "contact_share", "full_lifecycle"],
      "description": "Which Component 2 flow the AI agent is invoking. `off_protocol` records that ATAH was not invoked beyond Discovery (the consumer-facing surface acted on Discovery results without further ATAH mediation). `contact_share` is a single-stage flow: consumer consents, contact details flow through the transient encrypted vault, professional retrieves through authenticated retrieval, vault crypto-erases on retrieval; no Stage 1 appetite check, no Stage 2 pre-handoff check. `full_lifecycle` is the Stage 1 / Stage 2 / Stage 3 lifecycle previously documented as the universal handoff path."
    },
    "requesting_agent": {
      "$ref": "principal-delegation.schema.json"
    },
    "consumer_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque platform-side reference. Not personally identifiable."
    },
    "professional_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "consent_receipt_id": {
      "type": "string",
      "pattern": "^cr-[A-Za-z0-9-]{6,64}$"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "query",
        "shortlist-returned",
        "introduction-initiated",
        "stage-1-pending",
        "stage-1-accepted",
        "stage-1-declined",
        "stage-1-timeout",
        "pending-stage-2",
        "stage-2-cleared",
        "stage-2-blocked",
        "stage-2-timeout",
        "pending-stage-3",
        "stage-3-released",
        "stage-3-cancelled",
        "introduction-complete",
        "outcome-reported",
        "closed",
        "consumer-cancelled",
        "consent-revoked",
        "data-deleted"
      ]
    },
    "state_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "state": { "type": "string", "minLength": 1 },
          "entered_at": { "type": "string", "format": "date-time" },
          "actor_type": {
            "type": "string",
            "enum": ["ai_platform", "professional", "consumer", "system", "admin"]
          },
          "note": { "type": "string" }
        },
        "required": ["state", "entered_at", "actor_type"],
        "additionalProperties": false
      }
    },
    "pre_handoff_check_type": {
      "type": "string",
      "enum": ["conflict_check", "scope_confirmation", "capacity_confirmation", "fee_alignment", "none"]
    },
    "outcome_code": {
      "type": "string",
      "enum": [
        "introduction-successful",
        "professional-declined-conflict",
        "professional-declined-scope",
        "professional-declined-capacity",
        "professional-declined-fee",
        "professional-declined-other",
        "consumer-chose-alternative",
        "matter-not-proceeding",
        "no-response-from-consumer",
        "consumer-reported-concern",
        "consumer-cancelled",
        "consent-revoked"
      ]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" },
    "cancelled_at": { "type": "string", "format": "date-time" },
    "consent_revoked_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "handoff_id",
    "schema_version",
    "protocol_version",
    "introduction_type",
    "flow_variant",
    "requesting_agent",
    "consumer_ref",
    "professional_id",
    "consent_receipt_id",
    "current_state",
    "state_history",
    "created_at",
    "last_updated"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "handoff_id": "hf-01HQXRC2T7UVWZ9ABCDE1FGHIJ",
      "schema_version": "0.8",
      "protocol_version": "0.8",
      "introduction_type": "component_2_consumer_handoff",
      "flow_variant": "full_lifecycle",
      "requesting_agent": {
        "authenticated_actor": {
          "actor_type": "ai_platform",
          "actor_id": "platform_openai_example"
        },
        "client_application": {
          "platform_id": "platform_openai_example",
          "client_id": "client_123"
        },
        "authority_context": {
          "represented_principal_type": "consumer",
          "authority_basis": "user_session",
          "permitted_scopes": ["atah:introductions:create", "atah:introductions:write"],
          "expires_at": "2026-04-10T15:21:00Z",
          "object_constraints": [
            { "constraint_type": "consent_receipt_id", "value": "cr-01HQXRB1S6TUVZ8A9BCD0EFGHI" }
          ]
        }
      },
      "consumer_ref": "opaque-platform-user-ref",
      "professional_id": "atah-01HQXR7K9NBVZ8M3PXFG2YT5WA",
      "consent_receipt_id": "cr-01HQXRB1S6TUVZ8A9BCD0EFGHI",
      "current_state": "stage-1-accepted",
      "state_history": [
        {
          "state": "introduction-initiated",
          "entered_at": "2026-04-10T14:21:00Z",
          "actor_type": "ai_platform"
        },
        {
          "state": "stage-1-pending",
          "entered_at": "2026-04-10T14:21:01Z",
          "actor_type": "system"
        },
        {
          "state": "stage-1-accepted",
          "entered_at": "2026-04-10T15:02:34Z",
          "actor_type": "professional"
        }
      ],
      "pre_handoff_check_type": "conflict_check",
      "created_at": "2026-04-10T14:21:00Z",
      "last_updated": "2026-04-10T15:02:34Z"
    }
  ]
}
