{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/professional-identity-established.schema.json",
  "title": "ATAH Professional Identity — Established Tier",
  "description": "ATAH Core Protocol object: established-tier professional profile (spec/v0.8 Section 4.7). The `membership` block replaces the credentialled tier's `licence`. Required for any ATAH-conformant implementation that produces or consumes professional profile objects.",
  "type": "object",
  "properties": {
    "atah_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "schema_version": { "type": "string", "const": "0.8" },
    "protocol_version": { "type": "string", "const": "0.8" },
    "professional_tier": { "type": "string", "const": "established" },
    "category": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "firm": { "type": "string", "minLength": 1 },
    "licensed_jurisdictions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "description": "Optional for established tier; required for credentialled tier."
    },
    "service_locations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "physical_locations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "remote_service_available": { "type": "boolean" },
    "specialisms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "matter_types": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "matching_status": {
      "type": "string",
      "enum": [
        "active",
        "compliance-pending",
        "regulatory-suspended",
        "admin-suspended",
        "pending-rollup",
        "pending-integrity-review",
        "contact_unverified",
        "withdrawn",
        "deceased"
      ]
    },
    "matching_status_reason": { "type": "string", "minLength": 1 },
    "registration_route": {
      "type": "string",
      "enum": ["partner", "individual"]
    },
    "acknowledged_rollup_terms": {
      "type": "boolean",
      "description": "Set at registration. MUST be true when registration_route is 'individual' (acknowledging that individual records may be absorbed into a partner roll-up if a relevant trusted partner subsequently joins, with the 7-day pre-merge notification window for high-risk regulated-tier categories per spec §10.4). May be omitted or false when registration_route is 'partner'."
    },
    "membership": {
      "type": "object",
      "properties": {
        "body": { "type": "string", "minLength": 1 },
        "level": { "type": "string", "minLength": 1 },
        "member_number": { "type": "string", "minLength": 1 },
        "verified_at": { "type": "string", "format": "date-time" },
        "disciplinary_record": {
          "type": "string",
          "enum": ["none_found", "present", "under_review"]
        }
      },
      "required": ["body", "level", "member_number", "verified_at"],
      "additionalProperties": false
    },
    "experience": {
      "type": "object",
      "properties": {
        "years_in_practice": { "type": "integer", "minimum": 0 },
        "years_in_specialism": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "response_time": {
      "type": "object",
      "properties": {
        "declared_hours": { "type": "integer", "minimum": 0 },
        "applies_to": { "type": "string", "enum": ["working_hours", "wall_clock_hours"] },
        "operating_timezone": { "type": "string", "minLength": 1 }
      },
      "required": ["declared_hours", "applies_to", "operating_timezone"],
      "additionalProperties": false
    },
    "engagement": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "virtual": { "type": "boolean" },
        "languages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z]{2,3}$" },
          "uniqueItems": true
        },
        "availability": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "referral_network": {
      "type": "object",
      "properties": {
        "inbound_relationship_count": { "type": "integer", "minimum": 0 },
        "inbound_relationship_quality_score": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "trusted_partner_data": {
      "type": "array",
      "items": { "$ref": "#/$defs/PartnerDataPayload" }
    },
    "enhanced_verification": {
      "type": "array",
      "items": {
        "$ref": "enhanced-verification.schema.json"
      }
    },
    "data_conflicts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "ai_assistant_connected": { "type": "boolean" },
    "profile_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "profile_maintained": { "type": "boolean" },
    "looking_for_referral_partners": {
      "type": "boolean",
      "default": false,
      "description": "Component 3 visibility toggle. When `true`, the professional is in the candidate pool for incoming Component 3 referral-partner Discovery and may receive `referral-proposal` records. When `false` (default), the professional is excluded from `request_intent: 'referral_partner_search'` results and cannot be the `target_professional_id` of a new proposal. Toggleable on and off at any time. Existing v0.8.1 records that omit the field MUST be read as `false`."
    },
    "notification_channels": {
      "type": "array",
      "description": "Per F-15 / spec §12A: the professional's notification channels with verification status. Drives the Layer 1 periodic verification mechanism, the Layer 2 escalation path, and the Layer 3 pre-handoff freshness check for high-stakes categories. Channels are stored on the professional record itself (not in a separate operational schema) so the matching engine's `contact_unverified` check is a single record read. Channel records carry an HMAC of the destination address (per the §11.8 HMAC-not-plain-hash requirement); the plaintext destination is held in the partner's or the implementation's own credential store. Migration note: existing v0.8.1 records have no `notification_channels` array (the array is new in v0.8.2); implementations create the array on first read for any existing record, populate channel records from existing notification configuration data, and set `last_verified: null` and `verification_status: not_yet_verified` for all migrated channels.",
      "items": { "$ref": "#/$defs/NotificationChannel" }
    },
    "_provenance": {
      "$ref": "provenance-map.schema.json"
    }
  },
  "required": [
    "atah_id",
    "schema_version",
    "protocol_version",
    "professional_tier",
    "category",
    "name",
    "service_locations",
    "remote_service_available",
    "specialisms",
    "matching_status",
    "registration_route",
    "membership"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "registration_route": { "const": "individual" } },
        "required": ["registration_route"]
      },
      "then": {
        "required": ["acknowledged_rollup_terms"],
        "properties": { "acknowledged_rollup_terms": { "const": true } }
      }
    }
  ],
  "$defs": {
    "NotificationChannel": {
      "type": "object",
      "description": "Per F-15 / spec §12A: a single notification channel with verification status. The `destination_reference` is an HMAC of the destination address (per §11.8 HMAC-not-plain-hash); ATAH does not need the plaintext address to verify freshness — the partner or implementation's credential store holds it. The `verification_status` lifecycle: `not_yet_verified` → `verification_pending` (challenge issued) → `verified` (challenge confirmed) → `escalation_pending` (Layer 2 escalation triggered) → `unverified` (full grace period elapsed; matching_status flips to `contact_unverified`).",
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 1,
          "description": "Opaque identifier for this channel record."
        },
        "channel_type": {
          "type": "string",
          "enum": ["email", "phone_voice", "phone_sms", "mcp_push", "webhook"]
        },
        "destination_reference": {
          "type": "string",
          "minLength": 1,
          "description": "HMAC of the destination address (email, phone number, MCP push endpoint, webhook URL) under the per-context audit HMAC key (per §11.8). Plaintext destination is NOT stored here; it is held by the partner or the implementation's own credential store. ATAH uses the HMAC to verify channel identity over time without learning the plaintext."
        },
        "delivery_purpose": {
          "type": "string",
          "enum": [
            "discovery_notification",
            "handoff_stage_1",
            "handoff_stage_2",
            "handoff_stage_3",
            "handoff_stage_3_alternate",
            "referral_proposal",
            "referral_connection",
            "account_alert",
            "verification_challenge"
          ]
        },
        "is_primary": {
          "type": "boolean",
          "description": "Whether this is the primary channel for the given `delivery_purpose`. At most one channel per delivery_purpose per professional MAY be marked primary; non-primary channels are fallbacks."
        },
        "last_verified": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Timestamp of the last successful verification challenge. `null` permitted only for newly-added channels not yet through their first verification cycle (`verification_status: not_yet_verified`)."
        },
        "verification_status": {
          "type": "string",
          "enum": ["verified", "verification_pending", "escalation_pending", "unverified", "not_yet_verified"]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["channel_id", "channel_type", "destination_reference", "delivery_purpose", "is_primary", "last_verified", "verification_status", "created_at"],
      "additionalProperties": false
    },
    "PartnerDataPayload": {
      "type": "object",
      "properties": {
        "partner_id": { "type": "string", "pattern": "^tp-[A-Za-z0-9-]{6,64}$" },
        "partner_name": { "type": "string", "minLength": 1 },
        "partner_type": {
          "type": "string",
          "enum": [
            "regulatory_database",
            "professional_body",
            "review_platform",
            "independent_verifier",
            "firm_or_institution"
          ]
        },
        "data_points": {
          "type": "object",
          "description": "Partner-supplied structured data points. Open object — content varies by partner_type and category.",
          "additionalProperties": true
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "trust_tier": {
          "type": "string",
          "enum": ["partner-verified", "probationary-partner", "suspended-partner", "revoked-partner"]
        }
      },
      "required": ["partner_id", "partner_name", "partner_type", "data_points", "last_updated", "trust_tier"],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "atah_id": "atah-01HQXR8M2P3QRV5WTYZAB6CDEF",
      "schema_version": "0.8",
      "protocol_version": "0.8",
      "professional_tier": "established",
      "category": "pr_professional",
      "name": "Alex Johnson",
      "firm": "Johnson Communications Ltd",
      "service_locations": ["GB-LON"],
      "physical_locations": ["London, UK"],
      "remote_service_available": true,
      "specialisms": ["corporate_communications", "crisis_management"],
      "matching_status": "active",
      "registration_route": "partner",
      "membership": {
        "body": "Chartered Institute of Public Relations",
        "level": "Fellow",
        "member_number": "FCIPR-12345",
        "verified_at": "2026-04-01T00:00:00Z"
      },
      "trusted_partner_data": [
        {
          "partner_id": "tp-cipr-001",
          "partner_name": "Chartered Institute of Public Relations",
          "partner_type": "professional_body",
          "data_points": {
            "membership_status": "fellow",
            "member_since": "2011-03-01",
            "cpd_compliant": true,
            "disciplinary_record": "none_found"
          },
          "last_updated": "2026-04-01T00:00:00Z",
          "trust_tier": "partner-verified"
        }
      ],
      "enhanced_verification": [],
      "data_conflicts": [],
      "ai_assistant_connected": false,
      "profile_completeness_score": 0.88,
      "looking_for_referral_partners": false,
      "notification_channels": [
        {
          "channel_id": "ch-01HQXRQ4D5EFGHIJKLMNOPQRST",
          "channel_type": "email",
          "destination_reference": "hmac:d4735e3a265e16eee03f59718b9b5d03019c07d8b6c51f90da3a666eec13ab35",
          "delivery_purpose": "handoff_stage_1",
          "is_primary": true,
          "last_verified": "2026-04-01T11:00:00Z",
          "verification_status": "verified",
          "created_at": "2026-02-20T08:30:00Z"
        },
        {
          "channel_id": "ch-01HQXRQ5E6FGHIJKLMNOPQRSTU",
          "channel_type": "email",
          "destination_reference": "hmac:4b227777d4dd1fc61c6f884f48641d02b4d121d3fd328cb08b5531fcacdabf8a",
          "delivery_purpose": "handoff_stage_3",
          "is_primary": true,
          "last_verified": null,
          "verification_status": "verification_pending",
          "created_at": "2026-04-12T16:45:00Z"
        }
      ]
    }
  ]
}
