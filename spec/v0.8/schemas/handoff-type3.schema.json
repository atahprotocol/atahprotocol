{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/handoff-type3.schema.json",
  "title": "ATAH Handoff — Type 3 (Professional-Initiated Client Referral)",
  "description": "ATAH Core Protocol object: Type 3 professional-initiated client referral record (spec/v0.8 Section 6). Consent is polymorphic — either a structured client consent receipt or a professional attestation of underlying client consent. Required for any ATAH-conformant implementation.",
  "type": "object",
  "properties": {
    "referral_id": {
      "type": "string",
      "pattern": "^ref-[A-Za-z0-9-]{6,64}$"
    },
    "schema_version": { "type": "string", "const": "0.8" },
    "protocol_version": { "type": "string", "const": "0.8" },
    "introduction_type": {
      "type": "string",
      "enum": ["type_3_client_referral"]
    },
    "referring_professional_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "target_professional_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "consent": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "client_consent_receipt" },
            "consent_receipt_id": {
              "type": "string",
              "pattern": "^cr-[A-Za-z0-9-]{6,64}$"
            }
          },
          "required": ["type", "consent_receipt_id"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string", "const": "professional_attestation" },
            "client_consent_attestation": {
              "type": "object",
              "properties": {
                "attestation_id": {
                  "type": "string",
                  "pattern": "^att-[A-Za-z0-9-]{6,64}$"
                },
                "attesting_professional_id": {
                  "type": "string",
                  "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
                },
                "attestation_text_version": { "type": "string", "minLength": 1 },
                "captured_at": { "type": "string", "format": "date-time" },
                "evidence_basis": {
                  "type": "string",
                  "enum": [
                    "signed_engagement_letter",
                    "verbal_consent_recorded",
                    "existing_relationship_authorisation",
                    "other"
                  ]
                },
                "data_retention_compliant": { "type": "boolean" }
              },
              "required": [
                "attestation_id",
                "attesting_professional_id",
                "attestation_text_version",
                "captured_at",
                "evidence_basis",
                "data_retention_compliant"
              ],
              "additionalProperties": false
            }
          },
          "required": ["type", "client_consent_attestation"],
          "additionalProperties": false
        }
      ]
    },
    "client_data_vault_ref": {
      "type": "string",
      "pattern": "^vault-[A-Za-z0-9-]{6,64}$"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "referral-initiated",
        "referral-delivered",
        "contact-details-deleted",
        "referral-recorded"
      ]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" }
  },
  "required": [
    "referral_id",
    "schema_version",
    "protocol_version",
    "introduction_type",
    "referring_professional_id",
    "target_professional_id",
    "consent",
    "client_data_vault_ref",
    "current_state",
    "created_at",
    "last_updated"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "referral_id": "ref-01HQXRF5W0XYZABCDEF4IJKLMNO",
      "schema_version": "0.8",
      "protocol_version": "0.8",
      "introduction_type": "type_3_client_referral",
      "referring_professional_id": "atah-01HQXR7K9NBVZ8M3PXFG2YT5WA",
      "target_professional_id": "atah-01HQXR8M2P3QRV5WTYZAB6CDEF",
      "consent": {
        "type": "professional_attestation",
        "client_consent_attestation": {
          "attestation_id": "att-01HQXRG6X1YZABCDEF5JKLMNOPQ",
          "attesting_professional_id": "atah-01HQXR7K9NBVZ8M3PXFG2YT5WA",
          "attestation_text_version": "type3-attestation-v0.8",
          "captured_at": "2026-04-10T13:00:00Z",
          "evidence_basis": "signed_engagement_letter",
          "data_retention_compliant": true
        }
      },
      "client_data_vault_ref": "vault-01HQXRH7Y2ZABCDEF6KLMNOPQRS",
      "current_state": "referral-delivered",
      "created_at": "2026-04-10T13:00:00Z",
      "last_updated": "2026-04-10T13:30:00Z"
    }
  ]
}
