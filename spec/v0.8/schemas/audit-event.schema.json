{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/audit-event.schema.json",
  "title": "ATAH Audit Event",
  "description": "ATAH Core Protocol object: a single audit log entry returned by audit endpoints. Internal storage representation may differ; this is the over-the-wire shape. Required for any ATAH-conformant implementation (spec/v0.8 Section 13).",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque audit event identifier."
    },
    "schema_version": {
      "type": "string",
      "const": "0.8"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "introduction_initiated",
        "stage_advanced",
        "consent_asserted",
        "consent_revoked",
        "data_retrieved",
        "data_erased",
        "partner_data_pushed",
        "verifier_data_submitted",
        "admin_action",
        "dispute_raised",
        "dispute_resolved",
        "concern_flag_raised",
        "concern_flag_reviewed",
        "meaningful_conflict_detected",
        "partner_suspended",
        "verifier_suspended",
        "security_event"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "authenticated_actor": { "$ref": "principal-delegation.schema.json#/$defs/AuthenticatedActor" },
    "client_application": { "$ref": "principal-delegation.schema.json#/$defs/ClientApplication" },
    "authority_context": { "$ref": "principal-delegation.schema.json#/$defs/AuthorityContext" },
    "subject": {
      "type": "object",
      "properties": {
        "subject_type": {
          "type": "string",
          "enum": ["handoff", "professional", "partner", "verifier", "consent_receipt", "dispute", "flag"]
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["subject_type", "subject_id"],
      "additionalProperties": false
    },
    "request_id": {
      "type": ["string", "null"],
      "description": "Originating request_id, if any. Null for system-emitted events."
    },
    "metadata": {
      "type": "object",
      "description": "Open object for event-type-specific structured detail.",
      "additionalProperties": true
    }
  },
  "required": [
    "event_id",
    "schema_version",
    "event_type",
    "occurred_at",
    "authenticated_actor",
    "authority_context",
    "subject",
    "request_id"
  ],
  "additionalProperties": false,
  "if": {
    "properties": {
      "authenticated_actor": {
        "properties": { "actor_type": { "const": "ai_platform" } },
        "required": ["actor_type"]
      }
    },
    "required": ["authenticated_actor"]
  },
  "then": {
    "required": [
      "event_id",
      "schema_version",
      "event_type",
      "occurred_at",
      "authenticated_actor",
      "client_application",
      "authority_context",
      "subject",
      "request_id"
    ]
  },
  "examples": [
    {
      "event_id": "evt-01HQXRM1C6DEFGHIJKLMNOPQRS",
      "schema_version": "0.8",
      "event_type": "consent_asserted",
      "occurred_at": "2026-04-10T14:21:00Z",
      "authenticated_actor": {
        "actor_type": "ai_platform",
        "actor_id": "platform_openai_example"
      },
      "client_application": {
        "platform_id": "platform_openai_example",
        "client_id": "client_123"
      },
      "authority_context": {
        "represented_principal_type": "consumer",
        "authority_basis": "user_session",
        "permitted_scopes": ["atah:introductions:write"],
        "expires_at": "2026-04-10T15:21:00Z",
        "object_constraints": [
          { "constraint_type": "consent_receipt_id", "value": "cr-01HQXRB1S6TUVZ8A9BCD0EFGHI" }
        ]
      },
      "subject": {
        "subject_type": "consent_receipt",
        "subject_id": "cr-01HQXRB1S6TUVZ8A9BCD0EFGHI"
      },
      "request_id": "req-01HQXRM1C6DEFGHIJKLMNOPQRS",
      "metadata": {
        "scope": "stage_2_prehandoff_submission"
      }
    },
    {
      "event_id": "evt-01HQXRM2D7EFGHIJKLMNOPQRST",
      "schema_version": "0.8",
      "event_type": "partner_data_pushed",
      "occurred_at": "2026-04-10T09:00:00Z",
      "authenticated_actor": {
        "actor_type": "partner",
        "actor_id": "partner_solicitors_regulation_authority"
      },
      "authority_context": {
        "represented_principal_type": "partner",
        "authority_basis": "partner_credential",
        "permitted_scopes": ["atah:partner:data.write"]
      },
      "subject": {
        "subject_type": "partner",
        "subject_id": "partner_solicitors_regulation_authority"
      },
      "request_id": "req-01HQXRM2D7EFGHIJKLMNOPQRST",
      "metadata": {
        "batch_id": "batch-01HQXRN3E8FGHIJKLMNOPQRSTU",
        "records_accepted": 412,
        "records_rejected": 0
      }
    },
    {
      "event_id": "evt-01HQXRM3F8GHIJKLMNOPQRSTUV",
      "schema_version": "0.8",
      "event_type": "data_erased",
      "occurred_at": "2026-04-10T18:00:00Z",
      "authenticated_actor": {
        "actor_type": "system",
        "actor_id": "atah-system-vault-erasure"
      },
      "authority_context": {
        "represented_principal_type": "none",
        "authority_basis": "system_role"
      },
      "subject": {
        "subject_type": "handoff",
        "subject_id": "hf-01HQXRC2T7UVWZ9ABCDE1FGHIJ"
      },
      "request_id": null,
      "metadata": {
        "vault_ref": "vault-01HQXRH7Y2ZABCDEF6KLMNOPQRS",
        "erasure_reason": "stage_3_post_retrieval"
      }
    }
  ]
}
