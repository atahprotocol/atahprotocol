{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atahprotocol.org/spec/v0.8/schemas/handoff-type2.schema.json",
  "title": "ATAH Handoff — Type 2 (Referral Partner Proposal)",
  "description": "ATAH Core Protocol object: Type 2 referral partner proposal record (spec/v0.8 Section 6). Captures the mutual opt-in lifecycle for two professionals proposing a referral relationship. Required for any ATAH-conformant implementation.",
  "type": "object",
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^proposal-[A-Za-z0-9-]{6,64}$"
    },
    "schema_version": { "type": "string", "const": "0.8" },
    "protocol_version": { "type": "string", "const": "0.8" },
    "introduction_type": {
      "type": "string",
      "enum": ["type_2_referral_proposal"]
    },
    "initiating_professional_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "target_professional_id": {
      "type": "string",
      "pattern": "^atah-[A-Za-z0-9-]{6,64}$"
    },
    "consent_receipt_id": {
      "type": "string",
      "pattern": "^cr-[A-Za-z0-9-]{6,64}$"
    },
    "proposed_relationship": {
      "type": "object",
      "properties": {
        "category_alignment": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "jurisdiction_overlap": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "rationale": { "type": "string", "minLength": 1 }
      },
      "required": ["category_alignment", "jurisdiction_overlap", "rationale"],
      "additionalProperties": false
    },
    "current_state": {
      "type": "string",
      "enum": [
        "proposal-created",
        "pending-mutual-opt-in",
        "partner-1-accepted",
        "partner-2-accepted",
        "partner-2-declined",
        "partner-1-declined",
        "relationship-established",
        "relationship-declined",
        "expired"
      ]
    },
    "expires_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" }
  },
  "required": [
    "proposal_id",
    "schema_version",
    "protocol_version",
    "introduction_type",
    "initiating_professional_id",
    "target_professional_id",
    "consent_receipt_id",
    "proposed_relationship",
    "current_state",
    "expires_at",
    "created_at",
    "last_updated"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "proposal_id": "proposal-01HQXRE4V9WXYABCDEF3HIJKLM",
      "schema_version": "0.8",
      "protocol_version": "0.8",
      "introduction_type": "type_2_referral_proposal",
      "initiating_professional_id": "atah-01HQXR7K9NBVZ8M3PXFG2YT5WA",
      "target_professional_id": "atah-01HQXR8M2P3QRV5WTYZAB6CDEF",
      "consent_receipt_id": "cr-01HQXRB1S6TUVZ8A9BCD0EFGH2",
      "proposed_relationship": {
        "category_alignment": ["lawyer", "tax_planner"],
        "jurisdiction_overlap": ["US-TX"],
        "rationale": "Frequent cross-referrals for cross-border M&A; mutual sign-off requested."
      },
      "current_state": "pending-mutual-opt-in",
      "expires_at": "2026-05-10T14:21:00Z",
      "created_at": "2026-04-10T14:21:00Z",
      "last_updated": "2026-04-10T14:21:00Z"
    }
  ]
}
